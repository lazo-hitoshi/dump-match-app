# Supabase
# Project Settings → API からコピー
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# 推奨: Legacy の「anon public」キー（eyJhbGci... で始まる JWT）
# 新しい Publishable key（sb_publishable_...）でも可
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server only (optional for admin scripts)
# Legacy の「service_role」キー（eyJhbGci...）または Secret key（sb_secret_...）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
